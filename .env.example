# ============================================================
# .env.example — Template biến môi trường
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên Git
# ============================================================

# ---- Google Sheets ----
SPREADSHEET_ID=your_spreadsheet_id_here

# ---- Google Service Account (JSON dạng string, dùng cho GitHub Actions) ----
# Cách lấy: đọc nội dung file excel_key.json, paste nguyên vào đây (1 dòng)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"..."}

# ---- Đường dẫn file credentials (dùng khi chạy local) ----
CREDENTIALS_FILE=excel_key.json

# ---- Crawl settings ----
# Số ngày lịch sử cổ phiếu cần lấy
STOCK_HISTORY_DAYS=365
# Số giây delay giữa các request (tránh bị block)
REQUEST_DELAY=0.5
# Timeout cho mỗi request (giây)
REQUEST_TIMEOUT=15
# Timeout cho Playwright page load (ms)
PLAYWRIGHT_TIMEOUT=45000
